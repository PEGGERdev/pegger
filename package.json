{
  "name": "pegger-dev-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "node --experimental-vm-modules scripts/run-tests.js",
    "test:e2e": "playwright test",
