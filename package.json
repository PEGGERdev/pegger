    "@fontsource/space-grotesk": "^5.2.10",
    "@vueuse/core": "^13.0.0",
    "aos": "^2.3.4",
    "bootstrap-icons": "^1.13.1",
    "bootswatch": "^5.3.8",
    "tsparticles": "^3.8.1",
    "vue": "^3.5.25",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.6.0",
    "vite": "^7.3.6",
    "vue-tsc": "^2.2.0"
  }
}
